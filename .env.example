# Configuração de Ambiente - AlmoxPro

# Modo do Servidor
NODE_ENV=development

# Configuração Supabase (para modo Vercel)
SUPABASE_URL=seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anonima
SUPABASE_SERVICE_KEY=sua-chave-servico

# Configuração Licenças
LICENSE_SERVER=https://almoxpro.vercel.app/api
JWT_SECRET=seu-jwt-secret

# Configuração Pagamentos
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Configuração Vercel
VERCEL_PROJECT_NAME=almoxpro
VERCEL_DOMAIN=seu-dominio.com
